class Solution {
public:
    bool isPalindrome(int x) {
        long long num=x;
        long long rev=0;
        int rem=0;
        while(x!= 0){
            rem=x%10;
            rev=rev*10 +rem;
            x=x/10;


        }
        if(rev==num && num>=0) {
            
            return true;
        }else{
            return false;
        }
        
        
    }
};
